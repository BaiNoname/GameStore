@model List<GameStore.Models.Game>
@{
    ViewData["Title"] = "Home";
}

    <!-- Main -->
    <main class="gs-page">
        <div class="container-xxl">
        <h2 class="gs-section-title">
            @(ViewBag.CategoryName ?? "All Games")
        </h2>

            <!-- Featured cards -->
            <div class="gs-featured">

                @foreach (var game in Model)
                {
                    <article class="gs-card mb-4 shadow rounded-4 overflow-hidden">
                        <div class="row g-0 align-items-stretch">

                            <!-- Hình game -->
                            <div class="col-12 col-lg-7">
                                <div class="gs-media h-100">
                                    <img src="~/images/@game.Hinh" alt="@game.TenGame"
                                         class="img-fluid w-100 h-100 object-fit-cover">
                                </div>
                            </div>

                            <!-- Thông tin -->
                            <div class="col-12 col-lg-5">
                                <div class="gs-card-body d-flex flex-column h-100 p-4">

                                    <span class="badge bg-dark text-light mb-2">
                                        @game.MaTheLoai
                                    </span>

                                <h3 class="gs-card-title fw-bold mb-2 text-center">
                                        @game.TenGame
                                    </h3>

                                    <div class="mb-3 text-center">
                                        <div>
                                            <strong>Mã game:</strong> @game.MaGame
                                        </div>
                                        <div>
                                            <strong>Lượt tải:</strong> @game.SoLuotTai
                                        </div>
                                    </div>

                                    <div class="mt-auto d-flex justify-content-between align-items-center">

                                        <!-- Giá -->
                                        <span class="gs-price text-warning fw-bold fs-5">
                                            @String.Format("{0:N0} VNĐ", game.Gia)
                                        </span>
                                        <!-- Nút -->
                                        <a class="btn btn-info rounded-pill px-4"
                                           href="">
                                            Buy
                                        </a>
                                        <!-- Nút -->
                                        <a class="btn btn-warning rounded-pill px-4"
                                           href="/Game/Detail/@game.MaGame">
                                            Detail
                                        </a>

                                    </div>

                                </div>
                            </div>

                        </div>
                    </article>
                }

            </div>
        </div>
    </main>

