<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>GameStore - Steam-ish</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Your CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <!-- Top Navbar -->
    <header class="gs-topbar">
        <div class="container-xxl">
            <div class="d-flex align-items-center justify-content-between py-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="gs-logo">
                        <span class="gs-logo-mark">◎</span>
                        <span class="gs-logo-text">STEAM</span>
                    </div>

                    <nav class="d-none d-md-flex align-items-center gap-4 gs-topnav">
                        <a href="#">STORE</a>
                        <a href="#">COMMUNITY</a>
                        <a href="#">ABOUT</a>
                        <a href="#">SUPPORT</a>
                    </nav>
                </div>

                <div class="d-flex align-items-center gap-3">
                    <a class="gs-toplink" href="#">sign in</a>
                    <span class="gs-sep">|</span>
                    <a class="gs-toplink gs-accent" href="#">chat with AI</a>
                </div>
            </div>
        </div>
    </header>

    <!-- Sub Navbar -->
    <section class="gs-subbar">
        <div class="container-xxl">
            <div class="gs-subbar-inner">
                <div class="d-flex align-items-center gap-3 flex-wrap">
                    <div class="dropdown">
                        <button class="btn gs-pill dropdown-toggle" data-bs-toggle="dropdown">
                            Browser
                        </button>
                        <ul class="dropdown-menu gs-dd">
                            <li><a class="dropdown-item" href="#">Top Sellers</a></li>
                            <li><a class="dropdown-item" href="#">New & Trending</a></li>
                            <li><a class="dropdown-item" href="#">Special Offers</a></li>
                        </ul>
                    </div>

                    <div class="dropdown">
                        <button class="btn gs-pill dropdown-toggle" data-bs-toggle="dropdown">
                            Recommendations
                        </button>
                        <ul class="dropdown-menu gs-dd">
                            <li><a class="dropdown-item" href="#">For You</a></li>
                            <li><a class="dropdown-item" href="#">By Genre</a></li>
                        </ul>
                    </div>

                    <div class="dropdown">
                        <button class="btn gs-pill dropdown-toggle" data-bs-toggle="dropdown">
                            Categories
                        </button>
                        <ul class="dropdown-menu gs-dd">
                            <li><a class="dropdown-item" href="#">Action</a></li>
                            <li><a class="dropdown-item" href="#">RPG</a></li>
                            <li><a class="dropdown-item" href="#">Co-op</a></li>
                        </ul>
                    </div>
                </div>

                <form class="gs-search ms-auto" role="search" onsubmit="return false;">
                    <input class="form-control gs-search-input" type="search" placeholder="Search games..." aria-label="Search">
                    <button class="btn gs-search-btn" type="submit" aria-label="Search">🔍</button>
                </form>
            </div>
        </div>
    </section>




    <!-- Main -->
    <main class="gs-page">
        <div class="container-xxl">
            <h2 class="gs-section-title">All Games</h2>

            <!-- Featured cards -->
            <div class="gs-featured">

                @foreach (var game in ViewBag.games)
                {
                    <article class="gs-card mb-4 shadow rounded-4 overflow-hidden">
                        <div class="row g-0 align-items-stretch">

                            <!-- Hình game -->
                            <div class="col-12 col-lg-7">
                                <div class="gs-media h-100">
                                    <img src="~/images/@game.Hinh" alt="@game.TenGame"
                                         class="img-fluid w-100 h-100 object-fit-cover">
                                </div>
                            </div>

                            <!-- Thông tin -->
                            <div class="col-12 col-lg-5">
                                <div class="gs-card-body d-flex flex-column h-100 p-4">

                                    <span class="badge bg-dark text-light mb-2">
                                        @game.MaTheLoai
                                    </span>

                                    <h3 class="gs-card-title fw-bold mb-2">
                                        @game.TenGame
                                    </h3>

                                    <div class="small text-muted mb-3">
                                        <div>
                                            <strong>Mã game:</strong> @game.MaGame
                                        </div>
                                        <div>
                                            <strong>Lượt tải:</strong> @game.SoLuotTai
                                        </div>
                                    </div>

                                    <div class="mt-auto d-flex justify-content-between align-items-center">

                                        <!-- Giá -->
                                        <span class="gs-price text-warning fw-bold fs-5">
                                            @String.Format("{0:N0} VNĐ", game.Gia)
                                        </span>
                                        <!-- Nút -->
                                        <a class="btn btn-info rounded-pill px-4"
                                           href="">
                                            Buy
                                        </a>
                                        <!-- Nút -->
                                        <a class="btn btn-warning rounded-pill px-4"
                                           href="/Game/Detail/@game.MaGame">
                                            Xem chi tiết
                                        </a>

                                    </div>

                                </div>
                            </div>

                        </div>
                    </article>
                }

            </div>
        </div>
    </main>

    <footer class="bg-dark text-secondary pt-4 pb-3 border-top">
        <div class="container">

            <!-- logo + copyright -->
            <div class="row align-items-start mb-3">

                <div class="col-md-9">
                    <img src="https://store.cloudflare.steamstatic.com/public/images/v6/logo_valve_footer.png"
                         style="height:25px;" class="mb-2">

                    <p class="small mb-1">
                        © 2026 Valve Corporation. All rights reserved. All trademarks are property of their respective owners in the US and other countries.
                    </p>

                    <p class="small">
                        VAT included in all prices where applicable.
                        <a href="#" class="footer-link">Privacy Policy</a> |
                        <a href="#" class="footer-link">Legal</a> |
                        <a href="#" class="footer-link">Accessibility</a> |
                        <a href="#" class="footer-link">Steam Subscriber Agreement</a> |
                        <a href="#" class="footer-link">Refunds</a> |
                        <a href="#" class="footer-link">Cookies</a>
                    </p>
                </div>

                <div class="col-md-3 text-md-end">
                    <img src="https://store.cloudflare.steamstatic.com/public/images/v6/logo_steam_footer.png"
                         style="height:30px;">
                </div>

            </div>

            <!-- menu -->
            <div class="row border-top pt-3 small">

                <div class="col-md-9">
                    <a href="#" class="footer-link me-3">About Valve</a>
                    <a href="#" class="footer-link me-3">Jobs</a>
                    <a href="#" class="footer-link me-3">Steamworks</a>
                    <a href="#" class="footer-link me-3">Steam Distribution</a>
                    <a href="#" class="footer-link me-3">Support</a>
                    <a href="#" class="footer-link me-3">Gift Cards</a>
                </div>

                <div class="col-md-3 text-md-end">
                    <a href="#" class="footer-link me-2">F</a>
                    <a href="#" class="footer-link me-2">X</a>
                    <a href="#" class="footer-link">🦋</a>
                </div>

            </div>

        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
