@{
    ViewData["Title"] = "Support";
}

<div class="container py-5 text-light">

    <div class="text-center mb-5">
        <h1 class="fw-bold">Support Center</h1>
        <p class="text-secondary">Need help? We're here for you.</p>
    </div>

    <div class="row g-4">

        <div class="col-md-4">
            <div class="card bg-dark text-light border-0 shadow h-100">
                <div class="card-body text-center">
                    <h4>❓ FAQ</h4>
                    <p class="text-secondary">
                        Find answers to common questions about games and accounts.
                    </p>
                    <button class="btn btn-outline-info">View FAQ</button>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-dark text-light border-0 shadow h-100">
                <div class="card-body text-center">
                    <h4>📧 Contact Us</h4>
                    <p class="text-secondary">
                        Send us a message if you need assistance.
                    </p>
                    <button class="btn btn-outline-info">Contact Support</button>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-dark text-light border-0 shadow h-100">
                <div class="card-body text-center">
                    <h4>🔧 Technical Help</h4>
                    <p class="text-secondary">
                        Having issues downloading or running a game?
                    </p>
                    <button class="btn btn-outline-info">Get Help</button>
                </div>
            </div>
        </div>

    </div>

</div>