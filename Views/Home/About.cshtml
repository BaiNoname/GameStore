@{
    ViewData["Title"] = "About";
}

<div class="container py-5 text-light">

    <div class="text-center mb-5">
        <h1 class="fw-bold">About GameStore</h1>
        <p class="text-secondary">Your digital platform for discovering amazing games</p>
    </div>

    <div class="row g-4">

        <div class="col-md-4">
            <div class="card bg-dark text-light h-100 border-0 shadow">
                <div class="card-body text-center">
                    <h4 class="mb-3">🎮 Our Mission</h4>
                    <p>
                        GameStore is built to help gamers discover,
                        explore and enjoy the best games from many genres.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-dark text-light h-100 border-0 shadow">
                <div class="card-body text-center">
                    <h4 class="mb-3">🚀 What We Offer</h4>
                    <p>
                        Browse trending games, explore categories,
                        and find new favorites easily with our modern UI.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-dark text-light h-100 border-0 shadow">
                <div class="card-body text-center">
                    <h4 class="mb-3">🤖 AI Recommendation</h4>
                    <p>
                        Our AI system helps recommend games
                        based on popularity and user interests.
                    </p>
                </div>
            </div>
        </div>

    </div>

</div>