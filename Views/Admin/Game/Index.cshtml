@model List<GameStore.Models.Game>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý Game";
}

<div class="card">
    <div class="card-body">
        <h4 class="card-title">Danh sách game</h4>
        <p class="card-subtitle mb-3">Quản lý toàn bộ game trong hệ thống</p>

        <!-- Search + Add Button -->
        <div class="d-flex justify-content-between align-items-center mb-3">

            <form method="get" action="/admin/game/index" class="d-flex" style="width:350px;">
                <input type="text"
                       name="keyword"
                       class="form-control me-2"
                       placeholder="Tìm game theo tên..." />

                <button type="submit" class="btn btn-success">
                    Search
                </button>
            </form>

            <a href="/admin/create" class="btn btn-primary">
                + Thêm game mới
            </a>

        </div>

        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Mã game</th>
                        <th>Tên game</th>
                        <th>Thể loại</th>
                        <th>Giá</th>
                        <th>Lượt tải</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var game in Model)
                    {
                        <tr>
                            <td>@game.MaGame</td>
                            <td>@game.TenGame</td>
                            <td>@game.MaTheLoai</td>
                            <td>@String.Format("{0:N0} VNĐ", game.Gia)</td>
                            <td>@game.SoLuotTai</td>
                            <td>
                                <a href="/admin/edit/@game.MaGame" class="btn btn-sm btn-warning">Sửa</a>
                                <a href="/admin/delete/@game.MaGame" class="btn btn-sm btn-danger">Xóa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <!-- Pagination UI only -->
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center mt-4 mb-0">
                    <li class="page-item disabled">
                        <a class="page-link" href="#">Previous</a>
                    </li>

                    <li class="page-item active">
                        <a class="page-link" href="#">1</a>
                    </li>

                    <li class="page-item">
                        <a class="page-link" href="#">2</a>
                    </li>

                    <li class="page-item">
                        <a class="page-link" href="#">3</a>
                    </li>

                    <li class="page-item">
                        <a class="page-link" href="#">4</a>
                    </li>

                    <li class="page-item">
                        <a class="page-link" href="#">5</a>
                    </li>

                    <li class="page-item">
                        <a class="page-link" href="#">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>
