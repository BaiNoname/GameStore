@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý User";
}

<div class="card">
    <div class="card-body">
        <h4 class="card-title">Danh sách Users</h4>
        <p class="card-subtitle mb-3">Quản lý toàn bộ Users trong hệ thống</p>

        <!-- Search + Add Button -->
        <div class="d-flex justify-content-between align-items-center mb-3">

            <form method="get" action="/admin/user/index" class="d-flex" style="width:350px;">
                <input type="text"
                       name="keyword"
                       class="form-control me-2"
                       placeholder="Tìm user theo email..." />

                <button type="submit" class="btn btn-success">
                    Search
                </button>
            </form>

            <a href="/admin/user/create" class="btn btn-primary">
                + Thêm User mới
            </a>

        </div>

        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>User ID</th>
                        <th>UserName</th>
                        <th>Email</th>
                        <th>Date Register</th>
                        <th>Role</th>
                        <th>Balance</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in ViewBag.users)
                    {
                        <tr>
                            <td>@user.MaNguoiDung</td>
                            <td>@user.TenNguoiDung</td>
                            <td>@user.Email</td>
                            <td>@user.NgayDangKy</td>
                            <td>@user.Quyen</td>
                            <td>@user.SoDu</td>
                            <td>
                                <a href="/admin/user/edit/@user.MaNguoiDung" class="btn btn-sm btn-warning">Sửa</a>
                                <a href="/admin/user/delete/@user.MaNguoiDung" class="btn btn-sm btn-danger">Xóa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <!-- Pagination UI only -->
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center mt-4 mb-0">
                    <li class="page-item disabled">
                        <a class="page-link" href="#">Previous</a>
                    </li>

                    <li class="page-item active">
                        <a class="page-link" href="#">1</a>
                    </li>

                    <li class="page-item">
                        <a class="page-link" href="#">2</a>
                    </li>

                    <li class="page-item">
                        <a class="page-link" href="#">3</a>
                    </li>

                    <li class="page-item">
                        <a class="page-link" href="#">4</a>
                    </li>

                    <li class="page-item">
                        <a class="page-link" href="#">5</a>
                    </li>

                    <li class="page-item">
                        <a class="page-link" href="#">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>
