<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - GameStore</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />

    @RenderSection("Styles", required: false)
</head>
<body>

    <!-- Top Navbar -->
    <header class="gs-topbar">
        <div class="container-xxl">
            <div class="d-flex align-items-center justify-content-between py-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="gs-logo">
                        <a href="/">
                            <img src="https://store.fastly.steamstatic.com/public/shared/images/header/logo_steam.svg?t=962016"
                                 width="176" height="44" alt="GameStore Logo">
                        </a>
                    </div>

                    <nav class="d-none d-md-flex align-items-center gap-4 gs-topnav">
                        <a href="/">STORE</a>
                        <a href="/Home/About">ABOUT</a>
                        <a href="/Home/Support">SUPPORT</a>
                    </nav>
                </div>

                <div class="d-flex align-items-center gap-3">
                    <a class="gs-toplink" href="/Auth/Login">Sign in</a>
                    <span class="gs-sep">|</span>
                    <a href="/cart" class="btn btn-outline-light">
                        🛒 Cart
                    </a>
                    <span class="gs-sep">|</span>
                    <a class="gs-toplink gs-accent" href="#">Chat with AI</a>
                    
                </div>
            </div>
        </div>
    </header>


    @if (ViewBag.HideSubBar == null)
    {
        <!-- Sub Navbar -->
        <section class="gs-subbar">
            <div class="container-xxl">
                <div class="gs-subbar-inner">
                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        <div class="dropdown">
                            <button class="btn gs-pill dropdown-toggle" data-bs-toggle="dropdown">
                                Recommendations
                            </button>

                            <ul class="dropdown-menu gs-dd">

                                <li>
                                    <a class="dropdown-item" href="/home?type=new">
                                        New Games
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item" href="/home?type=hot">
                                        Hot Games
                                    </a>
                                </li>

                            </ul>
                        </div>

                        <div class="dropdown">
                            <button class="btn gs-pill dropdown-toggle" data-bs-toggle="dropdown">
                                Categories
                            </button>
                            <ul class="dropdown-menu gs-dd">
                                <li><a class="dropdown-item" href="/Home">All</a></li>
                                @if (ViewBag.Categories != null)
                                {
                                    foreach (var c in ViewBag.Categories)
                                    {
                                        <li>
                                            <a class="dropdown-item" href="/home?category=@c.MaTheLoai">
                                                @c.TenLoaiGame
                                            </a>
                                        </li>
                                    }
                                }
                            </ul>
                        </div>
                    </div>

                    <form class="gs-search ms-auto" method="get" action="/home">
                        <input class="form-control gs-search-input"
                               type="text"
                               name="search"
                               placeholder="Search game..." />

                        <button class="btn gs-search-btn" type="submit">
                            Search
                        </button>
                    </form>
                </div>
            </div>
        </section>
    }
    

    <!-- Nội dung riêng từng trang -->
    <main>
        @RenderBody()
    </main>

    <footer class="bg-dark text-secondary pt-4 pb-3 border-top mt-5">
        <div class="container">

            <div class="row align-items-start mb-3">
                <div class="col-md-9">
                    <img src="https://store.cloudflare.steamstatic.com/public/images/v6/logo_valve_footer.png"
                         style="height:25px;" class="mb-2" alt="Valve Footer Logo">

                    <p class="small mb-1">
                        © 2026 Valve Corporation. All rights reserved. All trademarks are property of their respective owners in the US and other countries.
                    </p>

                    <p class="small">
                        VAT included in all prices where applicable.
                        <a href="#" class="footer-link">Privacy Policy</a> |
                        <a href="#" class="footer-link">Legal</a> |
                        <a href="#" class="footer-link">Accessibility</a> |
                        <a href="#" class="footer-link">Steam Subscriber Agreement</a> |
                        <a href="#" class="footer-link">Refunds</a> |
                        <a href="#" class="footer-link">Cookies</a>
                    </p>
                </div>

                <div class="col-md-3 text-md-end">
                    <img src="https://store.cloudflare.steamstatic.com/public/images/v6/logo_steam_footer.png"
                         style="height:30px;" alt="Steam Footer Logo">
                </div>
            </div>

            <div class="row border-top pt-3 small">
                <div class="col-md-9">
                    <a href="#" class="footer-link me-3">About Valve</a>
                    <a href="#" class="footer-link me-3">Jobs</a>
                    <a href="#" class="footer-link me-3">Steamworks</a>
                    <a href="#" class="footer-link me-3">Steam Distribution</a>
                    <a href="#" class="footer-link me-3">Support</a>
                    <a href="#" class="footer-link me-3">Gift Cards</a>
                </div>

                <div class="col-md-3 text-md-end">
                    <a href="#" class="footer-link me-2">F</a>
                    <a href="#" class="footer-link me-2">X</a>
                    <a href="#" class="footer-link">🦋</a>
                </div>
            </div>

        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>