@model GameStore.Models.Game

@{
    ViewData["Title"] = "Chi tiết game";
}

@section Styles {
    <link rel="stylesheet" href="~/css/game-detail.css" />
}

<div class="container py-4">
    <div class="detail-card">
        <div class="row g-0">

            <div class="col-12 col-lg-7">
                <div class="detail-card__image-wrap">
                    <img src="~/images/@Model.Hinh" alt="@Model.TenGame" class="detail-card__image" />
                </div>
            </div>

            <div class="col-12 col-lg-5">
                <div class="detail-card__content">

                    <div class="detail-card__top">
                        <span class="detail-card__genre">@Model.MaTheLoai</span>
                        <span class="detail-card__code">Mã: @Model.MaGame</span>
                    </div>

                    <h1 class="detail-card__title">@Model.TenGame</h1>

                    <div class="detail-card__price">
                        @String.Format("{0:N0}", Model.Gia) VNĐ
                    </div>

                    <div class="detail-card__info">
                        <div class="detail-card__info-item">
                            <span class="label">Mã game</span>
                            <span class="value">@Model.MaGame</span>
                        </div>

                        <div class="detail-card__info-item">
                            <span class="label">Thể loại</span>
                            <span class="value">@Model.MaTheLoai</span>
                        </div>

                        <div class="detail-card__info-item">
                            <span class="label">Ngày ra mắt</span>
                            <span class="value">
                                @(Model.NgayRaMat.HasValue? Model.NgayRaMat.Value.ToString() : "Chưa cập nhật")
                            </span>
                        </div>

                        <div class="detail-card__info-item">
                            <span class="label">Lượt tải</span>
                            <span class="value">@Model.SoLuotTai</span>
                        </div>
                    </div>

                    <div class="detail-card__description">
                        <h5>Mô tả game</h5>
                        <p>
                            @(string.IsNullOrWhiteSpace(Model.MoTa) ? "Chưa có mô tả cho game này." : Model.MoTa)
                        </p>
                    </div>

                    <div class="detail-card__actions">
                        <a href="#" class="btn btn-primary rounded-pill px-4">Mua ngay</a>
                        <a href="#" class="btn btn-warning rounded-pill px-4">Thêm vào giỏ</a>
                        <a href="/home" class="btn btn-danger rounded-pill px-4">Quay lại</a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>
<div class="container mt-5">

    <h3 class="text-light mb-4">⭐ Player Reviews</h3>

    <!-- Form viết đánh giá -->
    <div class="card bg-dark text-light mb-4 border-secondary">
        <div class="card-body">

            <h5 class="mb-3">Write a Review</h5>

            <form>
                <div class="mb-3">
                    <label class="form-label">Rating</label>
                    <select class="form-select bg-dark text-light border-secondary">
                        <option>⭐ 5 - Excellent</option>
                        <option>⭐ 4 - Good</option>
                        <option>⭐ 3 - Average</option>
                        <option>⭐ 2 - Bad</option>
                        <option>⭐ 1 - Terrible</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Your Review</label>
                    <textarea class="form-control bg-dark text-light border-secondary"
                              rows="3"
                              placeholder="Write your thoughts about this game..."></textarea>
                </div>

                <button class="btn btn-primary">Submit Review</button>

            </form>

        </div>
    </div>


    <!-- Danh sách review -->
    <div class="card bg-dark text-light border-secondary mb-3">
        <div class="card-body">

            <div class="d-flex justify-content-between">
                <strong>Player123</strong>
                <span class="text-warning">⭐⭐⭐⭐⭐</span>
            </div>

            <p class="text-secondary small mb-2">2 hours ago</p>

            <p>
                This game is amazing! Graphics are beautiful and gameplay is smooth.
                Definitely worth buying.
            </p>

        </div>
    </div>


    <div class="card bg-dark text-light border-secondary mb-3">
        <div class="card-body">

            <div class="d-flex justify-content-between">
                <strong>GameFan</strong>
                <span class="text-warning">⭐⭐⭐⭐</span>
            </div>

            <p class="text-secondary small mb-2">1 day ago</p>

            <p>
                Really fun gameplay but the story is a bit short.
                Still recommend it!
            </p>

        </div>
    </div>

</div>