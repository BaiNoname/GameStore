<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Steam Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #1b2838;
            color: white;
        }

        .login-box {
            background: #2a475e;
            padding: 40px;
            border-radius: 10px;
        }

        .form-control {
            background: #1b2838;
            border: 1px solid #66c0f4;
            color: white;
        }

            .form-control::placeholder {
                color: #aaa;
            }

        .btn-steam {
            background: #66c0f4;
            border: none;
            font-weight: bold;
        }
    </style>
</head>

<body>

    <div class="container vh-100 d-flex justify-content-center align-items-center">

        <div class="login-box col-md-4">

            <h2 class="text-center mb-4">Sign in to Steam</h2>

            <form>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="text" class="form-control" placeholder="Enter email">
                </div>

                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" class="form-control" placeholder="Enter password">
                </div>

                <div class="d-grid mb-3">
                    <button class="btn btn-steam">Sign In</button>
                </div>

                <div class="text-center">
                    <a href="#" class="text-info">Forgot password?</a>
                </div>

                <hr>

                <div class="text-center">
                    <p>No have account Steam?</p>
                    <a href="/Auth/Register" class="btn btn-outline-light w-100">Create an Account</a>
                </div>

            </form>

        </div>

    </div>

</body>
</html>